      "typeVersion": 4.1,
      "position": [
        700,
        150
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://smartchat-api.jssolucoeseservicos.com.br/message/sendMedia/{{ $json.body.evoInstance }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $json.body.evoToken }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { number: $json.body.data.phone, mediatype: 'image', mimetype: 'image/jpeg', caption: $json.body.data.message, media: $json.body.data.media, fileName: $json.body.data.fileName } }}",
        "options": {}
      },
      "id": "node-media-send",
      "name": "Enviar Mídia (Evolution)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        700,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://smartchat-api.jssolucoeseservicos.com.br/chat/whatsappNumbers/{{ $json.body.evoInstance }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $json.body.evoToken }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { numbers: [ $json.body.data.phone ] } }}",
        "options": {}
      },
      "id": "node-validate-number",
      "name": "Validar Número (Evolution)",
      "type": "n8n-nodes-base.httpRequest",
