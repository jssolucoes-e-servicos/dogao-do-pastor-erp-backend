      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://smartchat-api.jssolucoeseservicos.com.br/message/sendText/{{ $json.body.evoInstance }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $json.body.evoToken }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { number: $json.body.data.phone, text: $json.body.data.message } }}",
        "options": {}
      },
      "id": "22fd2dd9-0941-4770-96b1-4bbcc267e74d",
      "name": "Enviar Texto (Evolution)",
