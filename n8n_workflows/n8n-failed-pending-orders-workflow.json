      "id": "4f0a9b8c-7d1e-2f3a-4b5c-6d7e8f9a0b1c",
      "name": "Excel Node",
      "type": "n8n-nodes-base.spreadsheetFile",
      "typeVersion": 1,
      "position": [
        700,
        180
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = items[0].json.body.data || items[0].json.data;\nconst orders = data.orders || [];\nconst editionName = data.editionName || 'Relatório';\nconst generationDate = data.generationDate || '';\nconst fileName = items[0].json.fileName || 'report.pdf';\n\nlet html = `<html><head><meta charset=\"UTF-8\"></head><body><h1>Relatório: ${editionName}</h1><p>Gerado em: ${generationDate}</p><table border=\"1\" style=\"width:100%\"><tr><th>ID</th><th>Cliente</th><th>Valor</th><th>Status</th></tr>`;\n\norders.forEach(o => {\n  html += `<tr><td>${o.id}</td><td>${o.customerName}</td><td>${o.totalValueFormatted}</td><td>${o.paymentStatus}</td></tr>`;\n});\n\nhtml += \"</table></body></html>\";\n\nreturn [{\n  json: { ...items[0].json, html },\n  binary: {\n    data: {\n      data: Buffer.from(html).toString('base64'),\n      fileName: fileName,\n      mimeType: 'text/html'\n    }\n  }\n}];"
      },
      "id": "5a1b2c3d-4e5f-6a7b-8c9d-0e1f2a3b4c5d",
      "name": "HTML Builder",
