        "accessKey": "smart-platform",
        "secretKey": "spQ0eMtOnnkghUiRxmOX5l0gyU0IROCwrhLcnAh2",
        "operation": "upload",
        "bucketName": "dogao-do-pastor-documents",
        "binaryPropertyName": "data",
