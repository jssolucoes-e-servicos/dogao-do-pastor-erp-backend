generator client {
  provider        = "prisma-client"
  output          = "../src/generated"
  previewFeatures = ["fullTextSearchPostgres"]
  moduleFormat    = "cjs"
}

generator seedClient {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserTypesEnum {
  PARTNER
  CUSTOMER
  CONTRIBUTOR
}

enum VoucherStatusEnum {
  NEW
  REGISTERED
  USED
  CANCELLED
}

enum OrderStatusEnum {
  DIGITATION
  PENDING_PAYMENT
  PAID
  QUEUE
  PRODUCTION
  EXPEDITION
  DELIVERING
  DELIVERED
  CANCELLED
  REJECTED
}

enum SiteOrderStepEnum {
  CUSTOMER
  ORDER
  DELIVERY
  PAYMENT
  PIX
  CARD
  ANALYSIS
  THANKS
}

enum DeliveryOptionEnum {
  UNDEFINED
  PICKUP
  DELIVERY
  DONATE
  SCHEDULED
}

enum PaymentOriginEnum {
  PREORDER
  ORDER
  PDV
}

enum PaymentStatusEnum {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentProviderEnum {
  MERCADOPAGO
  MANUAL
}

enum PaymentMethodEnum {
  UNDEFINED
  PIX
  CARD
  CARD_CREDIT
  CARD_DEBIT
  POS
  MONEY
  TICKET
  PIX_OFFLINE
}

enum EmailStatusEnum {
  QUEUED
  SENDING
  SENT
  FAILED
  RETRYING
}

enum OrderOriginEnum {
  APP
  MANUAL
  SITE
  PDV
}

enum CommandStatusEnum {
  QUEUE
  PENDING
  IN_PRODUCTION
  PRODUCED
  EXPEDITION
  QUEUED_FOR_DELIVERY
  OUT_FOR_DELIVERY
  DELIVERED
}

enum DeliveryRouteStatusEnum {
  PENDING
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum DeliveryStopStatusEnum {
  PENDING
  DELIVERING
  DELIVERED
  SKIPPED
  FAILED
}

enum DonationEntryType {
  CREDIT
  DEBIT
}

enum WithdrawalStatusEnum {
  PENDING
  CONFIRMED
  READY
  COMPLETED
  DELIVERED
  CANCELLED
}

// ─── PUSH NOTIFICATIONS ───────────────────────────────────────

enum NotificationTypeEnum {
  SYSTEM // avisos de sistema — não pode desligar
  SALES // nova venda, pagamento confirmado
  ORDERS // atualização de pedido
  RANKING // ranking atualizado
  CELL // atividade da célula
  NETWORK // atividade da rede
}

model Contributor {
  id                     String                  @id @default(cuid())
  name                   String
  phone                  String?
  photo                  String?
  username               String?                 @unique
  password               String
  active                 Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  deletedAt              DateTime?
  cells                  Cell[]
  cellNetworks           CellNetwork[]
  deliveryPersons        DeliveryPerson[]
  permissions            Permission[]
  sellers                Seller[]
  userRoles              UserRole[]
  pushTokens             PushToken[]
  notificationPreference NotificationPreference?
  cellsMember            ContributorCell[]
  controlPermissions     ControlPermission[]

  @@map("contributors")
}

model Role {
  id                 String              @id @default(cuid())
  name               String              @unique
  description        String?
  active             Boolean             @default(true)
  dashboardCards     String[]            @default([]) @map("dashboard_cards")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  permissions        Permission[]
  users              UserRole[]
  controlPermissions ControlPermission[]

  @@map("roles")
}

model UserRole {
  id            String      @id @default(cuid())
  contributorId String
  roleId        String
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  contributor   Contributor @relation(fields: [contributorId], references: [id])
  role          Role        @relation(fields: [roleId], references: [id])

  @@unique([contributorId, roleId])
  @@map("user_roles")
}

model Module {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String
  ctrl        String
  page        String
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  permissions Permission[]
  controls    Control[]

  @@map("modules")
}

model Permission {
  id            String       @id @default(cuid())
  contributorId String?
  roleId        String?
  moduleId      String
  access        Boolean      @default(false)
  create        Boolean      @default(false)
  update        Boolean      @default(false)
  delete        Boolean      @default(false)
  report        Boolean      @default(false)
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  contributor   Contributor? @relation(fields: [contributorId], references: [id])
  module        Module       @relation(fields: [moduleId], references: [id])
  role          Role?        @relation(fields: [roleId], references: [id])

  @@map("permissions")
}

model File {
  id         String    @id @default(cuid())
  path       String    @unique
  fileName   String
  mimeType   String
  sizeBytes  Int
  uploadedBy String
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@map("files")
}

model Edition {
  id               String             @id @default(cuid())
  name             String             @unique
  productionDate   DateTime           @unique
  code             String             @unique
  saleStartDate    DateTime
  saleEndDate      DateTime
  autoEnableDate   DateTime?
  autoDisableDate  DateTime?
  limitSale        Int
  dogsSold         Int                @default(0)
  dogPrice         Float              @default(19.99)
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  commands         Command[]
  orders           Order[]
  settlements      SellerSettlement[]
  tickets          Ticket[]
  issuedVouchers   Voucher[]          @relation("VoucherIssuedEdition")
  redeemedVouchers Voucher[]          @relation("VoucherRedeemedEdition")
  purchaseOrders   PurchaseOrder[]
  stockMovements   StockMovement[]

  @@index([saleEndDate, saleStartDate])
  @@map("editions")
}

model CellNetwork {
  id           String       @id @default(cuid())
  name         String
  supervisorId String?
  phone        String
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  cells        Cell[]
  supervisor   Contributor? @relation(fields: [supervisorId], references: [id])

  @@map("cells_networks")
}

model Cell {
  id           String            @id @default(cuid())
  name         String
  networkId    String
  leaderId     String?
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?
  leader       Contributor?      @relation(fields: [leaderId], references: [id])
  network      CellNetwork       @relation(fields: [networkId], references: [id])
  sellers      Seller[]
  contributors ContributorCell[]

  @@map("cells")
}

model Seller {
  id            String             @id @default(cuid())
  name          String
  cellId        String
  contributorId String
  tag           String             @unique
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?
  orders        Order[]
  cell          Cell               @relation(fields: [cellId], references: [id])
  contributor   Contributor        @relation(fields: [contributorId], references: [id])
  settlements   SellerSettlement[]
  tickets       Ticket[]
  dependents    ContributorCell[]

  @@index([cellId])
  @@map("sellers")
}

model ContributorCell {
  id            String      @id @default(cuid())
  cellId        String
  contributorId String
  sellerId      String
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  cell          Cell        @relation(fields: [cellId], references: [id])
  contributor   Contributor @relation(fields: [contributorId], references: [id])
  sellerDefault Seller      @relation(fields: [sellerId], references: [id])

  @@index([cellId, contributorId, sellerId])
  @@map("contributors_cells")
}

model DeliveryPerson {
  id               String          @id @default(cuid())
  contributorId    String
  online           Boolean         @default(false)
  inRoute          Boolean         @default(false)
  pushSubscription Json?
  active           Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?
  contributor      Contributor     @relation(fields: [contributorId], references: [id])
  routes           DeliveryRoute[]

  @@map("delivery_persons")
}

model Customer {
  id            String            @id @default(cuid())
  name          String
  email         String?           @unique
  phone         String
  cpf           String?           @unique
  password      String
  knowsChurch   Boolean           @default(true)
  allowsChurch  Boolean           @default(true)
  firstRegister Boolean           @default(false)
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  addresses     CustomerAddress[]
  orders        Order[]
  vouchers      Voucher[]

  @@map("customers")
}

model CustomerAddress {
  id           String    @id @default(cuid())
  customerId   String
  street       String
  number       String
  neighborhood String
  city         String
  state        String
  zipCode      String
  complement   String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  customer     Customer  @relation(fields: [customerId], references: [id])
  orders       Order[]

  @@index([customerId, neighborhood])
  @@map("customers_addresses")
}

model Order {
  id                     String             @id @default(cuid())
  editionId              String
  customerId             String
  customerName           String
  customerPhone          String
  customerCPF            String
  sellerId               String
  sellerTag              String
  origin                 OrderOriginEnum    @default(SITE)
  totalValue             Float
  status                 OrderStatusEnum    @default(DIGITATION)
  siteStep               SiteOrderStepEnum  @default(CUSTOMER)
  paymentStatus          PaymentStatusEnum  @default(PENDING)
  paymentType            PaymentMethodEnum  @default(UNDEFINED)
  deliveryOption         DeliveryOptionEnum @default(UNDEFINED)
  deliveryTime           String?
  partnerId              String?
  addressId              String?
  observations           String?
  active                 Boolean            @default(true)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  deletedAt              DateTime?
  paymentReminderSent    Boolean            @default(false)
  createdByContributorId String?
  commands               Command[]
  deliveryStops          DeliveryStop[]
  donationsEntries       DonationEntry[]
  address                CustomerAddress?   @relation(fields: [addressId], references: [id])
  customer               Customer           @relation(fields: [customerId], references: [id])
  edition                Edition            @relation(fields: [editionId], references: [id])
  partner                Partner?           @relation(fields: [partnerId], references: [id])
  seller                 Seller             @relation(fields: [sellerId], references: [id])
  items                  OrderItem[]
  payments               Payment[]
  tickets                Ticket[]
  vouchers               Voucher[]

  @@index([origin, editionId, status, sellerId])
  @@map("orders")
}

model OrderItem {
  id                 String        @id @default(cuid())
  orderId            String
  unitPrice          Float
  removedIngredients String[]
  commanded          Boolean       @default(false)
  active             Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?
  order              Order         @relation(fields: [orderId], references: [id])
  vouchers           Voucher[]
  commandItems       CommandItem[]

  @@index([orderId])
  @@map("orders_items")
}

model Ticket {
  id        String    @id @default(cuid())
  editionId String
  number    String
  ordered   Boolean   @default(false)
  sellerId  String
  orderId   String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  edition   Edition   @relation(fields: [editionId], references: [id])
  order     Order?    @relation(fields: [orderId], references: [id])
  seller    Seller    @relation(fields: [sellerId], references: [id])

  @@index([editionId, sellerId, orderId])
  @@map("tickets")
}

model Voucher {
  id                String            @id @default(cuid())
  code              String            @unique
  issuedEditionId   String
  customerId        String?
  redeemedEditionId String?
  orderId           String?
  orderItemId       String?
  used              Boolean           @default(false)
  usedAt            DateTime?
  status            VoucherStatusEnum @default(NEW)
  active            Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?
  customer          Customer?         @relation(fields: [customerId], references: [id])
  issuedEdition     Edition           @relation("VoucherIssuedEdition", fields: [issuedEditionId], references: [id])
  order             Order?            @relation(fields: [orderId], references: [id])
  orderItem         OrderItem?        @relation(fields: [orderItemId], references: [id])
  redeemedEdition   Edition?          @relation("VoucherRedeemedEdition", fields: [redeemedEditionId], references: [id])

  @@index([customerId, redeemedEditionId, issuedEditionId])
  @@map("vouchers")
}

model Payment {
  id                String              @id @default(cuid())
  orderId           String
  origin            PaymentOriginEnum   @default(PREORDER)
  value             Float
  status            PaymentStatusEnum   @default(PENDING)
  provider          PaymentProviderEnum @default(MERCADOPAGO)
  providerPaymentId String?
  method            PaymentMethodEnum   @default(UNDEFINED)
  pixQrcode         String?
  pixCopyPaste      String?
  paymentUrl        String?
  cardToken         String?
  rawPayload        String?
  active            Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  order             Order               @relation(fields: [orderId], references: [id])

  @@index([providerPaymentId, orderId, status, provider])
  @@map("payments")
}

model Command {
  id           String            @id @default(cuid())
  sequentialId String            @unique
  orderId      String?
  editionId    String
  editionCode  Int
  sequence     Int
  printed      Boolean           @default(false)
  pdfUrl       String?
  sentWhatsApp Boolean           @default(false)
  sentAt       DateTime?
  quantity     Int?
  status       CommandStatusEnum @default(PENDING)
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?
  withdrawalId String?           @unique
  edition      Edition           @relation(fields: [editionId], references: [id])
  order        Order?            @relation(fields: [orderId], references: [id])
  withdrawal   Withdrawal?       @relation(fields: [withdrawalId], references: [id])
  commandItems CommandItem[]

  @@map("commands")
}

model CommandItem {
  id                 String    @id @default(cuid())
  command            Command   @relation(fields: [commandId], references: [id])
  commandId          String
  item               OrderItem @relation(fields: [itemId], references: [id])
  itemId             String
  removedIngredients String[]
  producced          Boolean   @default(false)
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  @@index([commandId, itemId, producced])
  @@map("commands_items")
}

model DailyReportSoldsCache {
  id        String    @id @default(cuid())
  type      String
  refId     String
  seller    String
  cell      String
  network   String
  orders    Int       @default(0)
  dogs      Int       @default(0)
  total     Int       @default(0)
  sentAt    DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("daily_report_sold_caches")
}

model DeliveryRoute {
  id               String                  @id @default(cuid())
  deliveryPersonId String
  startedAt        DateTime?
  finishedAt       DateTime?
  status           DeliveryRouteStatusEnum @default(PENDING)
  totalStops       Int                     @default(0)
  completedStops   Int                     @default(0)
  active           Boolean                 @default(true)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  deletedAt        DateTime?
  deliveryPerson   DeliveryPerson          @relation(fields: [deliveryPersonId], references: [id])
  stops            DeliveryStop[]

  @@index([deliveryPersonId, status])
  @@map("delivery_routes")
}

model DeliveryStop {
  id          String                 @id @default(cuid())
  routeId     String
  orderId     String
  sequence    Int
  status      DeliveryStopStatusEnum @default(PENDING)
  deliveredAt DateTime?
  skippedAt   DateTime?
  failedAt    DateTime?
  lat         Float?
  lng         Float?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  deletedAt   DateTime?
  order       Order                  @relation(fields: [orderId], references: [id])
  route       DeliveryRoute          @relation(fields: [routeId], references: [id])

  @@index([routeId, orderId])
  @@map("delivery_stops")
}

model SellerSettlement {
  id               String    @id @default(cuid())
  editionId        String
  sellerId         String
  totalTicketsSold Int
  totalValue       Float
  totalReturned    Int
  status           String    @default("PENDING")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  edition          Edition   @relation(fields: [editionId], references: [id])
  seller           Seller    @relation(fields: [sellerId], references: [id])

  @@index([editionId, sellerId])
  @@map("sellers_settlements")
}

model Partner {
  id               String          @id @default(cuid())
  name             String
  cnpj             String          @unique
  phone            String
  description      String?
  website          String?
  facebook         String?
  instagram        String?
  addressInLine    String
  street           String
  number           String
  neighborhood     String
  city             String
  state            String
  zipCode          String
  complement       String?
  responsibleName  String
  responsiblePhone String
  logo             String?
  password         String
  approved         Boolean         @default(false)
  active           Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?
  donationEntry    DonationEntry[]
  donations        Order[]
  withdrawals      Withdrawal[]

  @@map("partners")
}

model OtpVerification {
  id        String        @id @default(cuid())
  userId    String
  userType  UserTypesEnum
  code      String
  phone     String
  expiresAt DateTime
  used      Boolean       @default(false)
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  @@index([userId, code])
  @@map("otp_verifications")
}

model DonationEntry {
  id           String            @id @default(cuid())
  partnerId    String
  orderId      String?
  withdrawalId String?
  quantity     Int
  type         DonationEntryType
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?
  order        Order?            @relation(fields: [orderId], references: [id])
  partner      Partner           @relation(fields: [partnerId], references: [id])
  withdrawal   Withdrawal?       @relation(fields: [withdrawalId], references: [id])

  @@index([partnerId, type, orderId, withdrawalId])
  @@map("donation_entries")
}

model Withdrawal {
  id           String               @id @default(cuid())
  partnerId    String
  status       WithdrawalStatusEnum @default(PENDING)
  scheduledAt  DateTime
  active       Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  deletedAt    DateTime?
  commands     Command?
  donationLogs DonationEntry[]
  items        WithdrawalItem[]
  partner      Partner              @relation(fields: [partnerId], references: [id])

  @@index([partnerId, status])
  @@map("withdrawals")
}

model WithdrawalItem {
  id                 String     @id @default(cuid())
  withdrawalId       String
  quantity           Int
  removedIngredients String[]
  active             Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?
  withdrawal         Withdrawal @relation(fields: [withdrawalId], references: [id])

  @@index([withdrawalId])
  @@map("withdrawal_items")
}

model PushToken {
  id            String      @id @default(cuid())
  contributor   Contributor @relation(fields: [contributorId], references: [id])
  contributorId String
  token         String      @unique
  platform      String // 'ios' | 'android'
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([contributorId])
  @@map("push_tokens")
}

model NotificationPreference {
  id            String      @id @default(cuid())
  contributor   Contributor @relation(fields: [contributorId], references: [id])
  contributorId String      @unique
  sales         Boolean     @default(true)
  orders        Boolean     @default(true)
  ranking       Boolean     @default(true)
  cell          Boolean     @default(true)
  network       Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("notification_preferences")
}

model NotificationLog {
  id            String               @id @default(cuid())
  contributorId String?
  type          NotificationTypeEnum
  title         String
  body          String
  data          Json?
  sentAt        DateTime             @default(now())
  success       Boolean              @default(true)
  error         String?

  @@index([contributorId, type])
  @@map("notification_logs")
}

model Control {
  id                 String              @id @default(cuid())
  moduleId           String              @map("module_id")
  name               String
  slug               String              @unique
  description        String?
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")
  module             Module              @relation(fields: [moduleId], references: [id])
  controlPermissions ControlPermission[]

  @@index([moduleId])
  @@map("controls")
}

model ControlPermission {
  id            String       @id @default(cuid())
  controlId     String       @map("control_id")
  contributorId String?      @map("contributor_id")
  roleId        String?      @map("role_id")
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")
  control       Control      @relation(fields: [controlId], references: [id])
  contributor   Contributor? @relation(fields: [contributorId], references: [id])
  role          Role?        @relation(fields: [roleId], references: [id])

  @@unique([controlId, contributorId])
  @@unique([controlId, roleId])
  @@index([controlId])
  @@map("control_permissions")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedBy   String?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

// ─── COMPRAS & ESTOQUE ────────────────────────────────────────

enum StockMovementTypeEnum {
  PURCHASE_IN // entrada por compra
  PRODUCTION_OUT // saída para produção
  SURPLUS_DONATE // sobra doada para células
  SURPLUS_SELL // sobra vendida
  SURPLUS_DISCARD // sobra descartada
  ADJUSTMENT // ajuste manual
}

model StockProduct {
  id          String    @id @default(cuid())
  name        String    @unique // "Salsicha", "Pão", "Embalagem", etc.
  unit        String // "kg", "unidade", "pacote"
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  purchaseItems  PurchaseItem[]
  stockMovements StockMovement[]

  @@map("stock_products")
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  editionId    String
  supplierId   String? // nome livre por enquanto
  supplierName String?
  notes        String?
  totalValue   Float     @default(0)
  orderedAt    DateTime  @default(now())
  deliveredAt  DateTime?
  createdById  String? // contributorId de quem criou
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  edition Edition        @relation(fields: [editionId], references: [id])
  items   PurchaseItem[]

  @@index([editionId])
  @@map("purchase_orders")
}

model PurchaseItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Float
  unitPrice       Float
  totalPrice      Float
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product       StockProduct  @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId, productId])
  @@map("purchase_items")
}

model StockMovement {
  id          String                @id @default(cuid())
  productId   String
  editionId   String
  type        StockMovementTypeEnum
  quantity    Float
  notes       String?
  createdById String? // contributorId
  active      Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  deletedAt   DateTime?

  product StockProduct @relation(fields: [productId], references: [id])
  edition Edition      @relation(fields: [editionId], references: [id])

  @@index([productId, editionId, type])
  @@map("stock_movements")
}
