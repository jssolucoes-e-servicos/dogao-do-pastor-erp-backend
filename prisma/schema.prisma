generator client {
  provider = "prisma-client-js"
  //output   = "../src/modules/prisma/client/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum VoucherStats {
  new
  registred
  used
  cancelled
}

enum OrderStats {
  digitation // Pedido em digitação no online
  pending_payment // Quando pedido online esta finalizado, mas sem pagamento
  payd // Quando pedido online recebe Pagamento
  new // Quando pedido novo (PDV)
  queue // Quando na fila esperando para horario de produção
  production // Quando estiver na produção
  expedition // Quando Termicada produção, estiver no balcão
  delivering // Quando sai para entrega
  delivered // Quando com estatus de já entregue
  cancelled // Quando cancelado
  rejected // Quando pedido rejeitado pelo sistema (não pago)
}

enum PreOrderStep {
  customer
  order
  delivery
  payment
  pix
  card
  analysis
  tanks
}

enum DeliveryOption {
  undefined
  pickup
  delivery
  donate
}

enum PaymentOrigin {
  preorder
  order
  pdv
}

enum PaymentStats {
  pending
  paid
  failed
  cancelled
  refunded
}

enum PaymetProviders {
  mercadopago
}

enum PaymentMethod {
  undefined
  pix
  card
  card_credit
  card_debit
  pos
  monney
}

enum EmailStatusEnum {
  QUEUED
  SENDING
  SENT
  FAILED
  RETRYING
}

enum OrderOrigin {
  SITE
  TICKET
  PDV
}

model Admin {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  username  String    @unique
  password  String
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("admins")
}

model User {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  username       String           @unique
  password       String
  active         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @default(now()) @updatedAt
  deletedAt      DateTime?
  Seller         Seller[]
  Cell           Cell[]
  CellNetwork    CellNetwork[]
  DeliveryPerson DeliveryPerson[]
  userRoles      UserRole[]
  permissions    Permission[]

  @@map("users")
}

model Role {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String // 'Seller', 'DeliveryPerson', 'ProductionManager', 'Backoffice', 'Reception'
  description String?
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
  deletedAt   DateTime?
  users       UserRole[]
  permissions Permission[]

  @@unique([name])
  @@map("roles")
}

model UserRole {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  role      Role     @relation(fields: [roleId], references: [id])
  roleId    String   @db.ObjectId
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Module {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  ctrl        String
  page        String
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
  deletedAt   DateTime?
  permissions Permission[]

  @@map("modules")
}

model Permission {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  user      User?     @relation(fields: [userId], references: [id])
  userId    String?   @db.ObjectId
  role      Role?     @relation(fields: [roleId], references: [id])
  roleId    String?   @db.ObjectId
  module    Module    @relation(fields: [moduleId], references: [id])
  moduleId  String    @db.ObjectId
  access    Boolean   @default(false)
  create    Boolean   @default(false)
  update    Boolean   @default(false)
  delete    Boolean   @default(false)
  report    Boolean   @default(false)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("permissions")
}

model File {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  path       String @unique // O caminho completo do arquivo no MinIO/S3
  fileName   String
  mimeType   String
  sizeBytes  Int
  uploadedBy String // personId que fez o upload

  // Opcional: Para vincular o arquivo a uma entidade específica (Ex: Profile Picture, Fatura PDF)
  entityId   String? // ID do registro onde este arquivo está sendo usado
  entityType String? // Ex: 'person', 'invoice', 'product'
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@map("files")
}

model EmailLog {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  senderId     String? // personId que disparou o envio
  to           String
  subject      String
  templateName String? // Ex: 'welcome', 'password_reset'

  // Status do envio
  status       EmailStatusEnum @default(QUEUED) // 'QUEUED', 'SENDING', 'SENT', 'FAILED', 'RETRYING'
  errorMessage String?
  sentAt       DateTime?

  // Conteúdo (para debug ou reenvio)
  contextSnapshot Json? // JSON dos dados que preencheram o template (para reenvio)
  attemptCount    Int       @default(0)
  // Padrões de CRUD
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? // Geralmente não se usa soft delete em logs, mas mantemos o padrão

  @@map("email_logs")
}

// Definindo a edição do evento
model Edition {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  productionDate DateTime
  dogPrice       Float     @default(19.99)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  vouchers     Voucher[]
  tickets      Tickets[]
  ordersOnline OrderOnline[]

  @@map("editions")
}

model CellNetwork {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  supervisorName String
  phone          String
  user           User?     @relation(fields: [userId], references: [id])
  userId         String?   @db.ObjectId
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  cells Cell[]

  @@map("cells_networks")
}

model Cell {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  network    CellNetwork @relation(fields: [networkId], references: [id])
  networkId  String      @db.ObjectId
  leaderName String
  phone      String?
  user       User?       @relation(fields: [userId], references: [id])
  userId     String?     @db.ObjectId
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?
  sellers    Seller[]

  @@map("cells")
}

model Seller {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  cell      Cell      @relation(fields: [cellId], references: [id])
  cellId    String    @db.ObjectId
  name      String
  phone     String
  tag       String    @unique
  user      User?     @relation(fields: [userId], references: [id])
  userId    String?   @db.ObjectId
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tickets      Tickets[]
  ordersOnline OrderOnline[]

  @@map("sellers")
}

model DeliveryPerson {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  phone          String?
  user           User?           @relation(fields: [userId], references: [id])
  userId         String?         @db.ObjectId
  online         Boolean         @default(false)
  inRoute        Boolean         @default(false)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  deliveryRoutes DeliveryRoute[]

  @@map("delivery_persons")
}

model Order {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  active     Boolean     @default(true)
  deleted    Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?
  vouchers   Voucher[]
  orderItems OrderItem[]

  @@map("orders")
}

model Voucher {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  edition     Edition      @relation(fields: [editionId], references: [id])
  editionId   String       @db.ObjectId
  cod         String
  customer    Customer?    @relation(fields: [customerId], references: [id])
  customerId  String?      @db.ObjectId
  order       Order?       @relation(fields: [orderId], references: [id])
  orderId     String?      @db.ObjectId
  orderItem   OrderItem?   @relation(fields: [orderItemId], references: [id])
  orderItemId String?      @db.ObjectId
  used        Boolean      @default(false)
  usedAt      DateTime?
  stats       VoucherStats @default(new)
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  @@map("vouchers")
}

model Tickets {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  editon    Edition   @relation(fields: [editionId], references: [id])
  editionId String    @db.ObjectId
  number    String
  orderd    Boolean   @default(false)
  seller    Seller    @relation(fields: [sellerId], references: [id])
  sellerId  String    @db.ObjectId
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("tickets")
}

model OrderItem {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  order     Order     @relation(fields: [orderId], references: [id])
  orderId   String    @db.ObjectId
  active    Boolean   @default(true)
  deleted   Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  vouchers  Voucher[]

  @@map("orders_items")
}

// Representa o cliente que está fazendo a pré-venda
model Customer {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String?           @unique
  phone         String
  cpf           String?           @unique
  password      String?           @default("dogao@25")
  knowsChurch   Boolean           @default(true)
  allowsChurch  Boolean           @default(true)
  firstRegister Boolean           @default(false)
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  vouchers      Voucher[]
  addresses     CustomerAddress[]
  ordersOnline  OrderOnline[]

  @@map("customers")
}

model CustomerAddress {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  customer     Customer  @relation(fields: [customerId], references: [id])
  customerId   String    @db.ObjectId
  street       String
  number       String
  neighborhood String
  city         String
  state        String
  zipCode      String
  complement   String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  ordersOnline OrderOnline[]

  @@map("customers_addresses")
}

model Payment {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  origin        PaymentOrigin    @default(preorder)
  idReference   String           @db.ObjectId
  value         Float
  paymentStatus PaymentStats?    @default(pending)
  provider      PaymetProviders? @default(mercadopago) // 'mercadopago'
  paymentId     String?
  method        PaymentMethod?   @default(undefined)
  pixQrcode     String?
  pixCopyPaste  String?
  paymentUrl    String? //url payment init
  cardToken     String?
  active        Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  @@map("payments")
}

// O pedido de pré-venda
model OrderOnline {
  id                  String           @id @default(auto()) @map("_id") @db.ObjectId
  customer            Customer?        @relation(fields: [customerId], references: [id])
  customerId          String?          @db.ObjectId
  edition             Edition          @relation(fields: [editionId], references: [id])
  editionId           String           @db.ObjectId
  seller              Seller           @relation(fields: [sellerId], references: [id])
  sellerId            String           @db.ObjectId
  sellerTag           String
  quantity            Int
  valueTotal          Float
  paymentStatus       String // 'pending', 'paid', 'failed'
  paymentProvider     String // 'mercadopago'
  paymentId           String? // ID da transação do Mercado Pago
  paymentUrl          String? //url payment init
  paymentMethod       String?          @default("NEW") // PIX  OU CARD - NEW apenas antes de ir para tela de pgto
  paymentPixQrcode    String?
  paymentPixCopyPaste String?
  address             CustomerAddress? @relation(fields: [customerAddressId], references: [id])
  customerAddressId   String?          @db.ObjectId
  observations        String?
  deliveryOption      DeliveryOption   @default(undefined)
  status              OrderStats       @default(digitation)
  isPromo             Boolean          @default(false)
  step                PreOrderStep     @default(customer)
  origin              OrderOrigin      @default(SITE)
  active              Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  deletedAt           DateTime?

  preOrderItems OrderOnlineItem[]
  deliveryStops DeliveryStop[]

  @@map("orders-online")
}

// O item do pedido de pré-venda, que representa um único cachorro-quente
model OrderOnlineItem {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  orderOnline        OrderOnline @relation(fields: [orderOnlineId], references: [id])
  orderOnlineId      String      @db.ObjectId
  removedIngredients String[] // Lista de ingredientes removidos
  active             Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?

  @@map("orders-online_items")
}

type DailyReportSoldsCacheSummaryType {
  Seller  String
  Cell    String
  Network String
  Orders  Int    @default(0)
  Dogs    Int    @default(0)
  Total   Int    @default(0)
}

model DailyReportSoldsCache {
  id        String                           @id @default(auto()) @map("_id") @db.ObjectId
  type      String // 'seller' ou 'cell'
  refId     String // id do vendedor ou da célula
  summary   DailyReportSoldsCacheSummaryType // { Pedidos, Dogs, Total }
  sentAt    DateTime                         @default(now())
  createdAt DateTime                         @default(now())
  updatedAt DateTime                         @updatedAt

  @@map("daily_report_solds_cache")
}

model DeliveryRoute {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  deliveryPerson   DeliveryPerson @relation(fields: [deliveryPersonId], references: [id])
  deliveryPersonId String         @db.ObjectId
  startedAt        DateTime?
  finishedAt       DateTime?
  status           String         @default("pending") // pending | in_progress | finished | cancelled
  totalStops       Int            @default(0)
  completedStops   Int            @default(0)
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  stops            DeliveryStop[]

  @@map("delivery_routes")
}

model DeliveryStop {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  route       DeliveryRoute @relation(fields: [routeId], references: [id])
  routeId     String        @db.ObjectId
  order       OrderOnline   @relation(fields: [orderId], references: [id])
  orderId     String        @db.ObjectId
  sequence    Int
  status      String        @default("pending") // pending | delivering | delivered | skipped | failed
  deliveredAt DateTime?
  skippedAt   DateTime?
  failedAt    DateTime?
  lat         Float?
  lng         Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("delivery_stops")
}
